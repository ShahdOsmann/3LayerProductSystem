@model ProductSystem.BLL.ViewModels.ProductDetailsVM

@{
    ViewData["Title"] = "Product Details";
}

<h2 class="text-primary text-center mb-4">Product Details</h2>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg">

                @if (string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="~/images/default.png"
                         class="card-img-top"
                         alt="No Product Image">
                }
                else
                {
                    <img src="~/images/@Model.ImageUrl"
                         class="card-img-top"
                         alt="@Model.Title">
                }

                <div class="card-body">

                    <h4 class="card-title text-primary mb-3">
                        @Model.Title
                    </h4>

                    <p class="card-text">
                        <strong>Price:</strong>
                        @Model.Price.ToString("C")
                    </p>

                    <p class="card-text">
                        <strong>Count:</strong>
                        @Model.Count
                    </p>

                    <p class="card-text">
                        <strong>Description:</strong>
                        @Model.Description
                    </p>

                    <p class="card-text">
                        <strong>Expiry Date:</strong>
                        @Model.ExpiryDate.ToString("yyyy-MM-dd")
                    </p>

                    <p class="card-text">
                        <strong>Category:</strong>
                        @Model.CategoryName
                    </p>

                    <div class="mt-3 d-flex gap-2">

                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-action="Index"
                           class="btn btn-secondary">
                            Back to Products
                        </a>

                    </div>

                </div>
            </div>

        </div>
    </div>
</div>