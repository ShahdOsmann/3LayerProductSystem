@model ProductSystem.BLL.ViewModels.Utilities.ResetPasswordVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header text-center">
                    <h4>Reset Password</h4>
                </div>

                <div class="card-body">

                    <form asp-action="ResetPassword" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div> 

                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input asp-for="Password" class="form-control" placeholder="Enter new password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success">
                                Reset Password
                            </button>
                        </div>

                    </form>

                </div>

                <div class="card-footer text-center">
                    <a asp-action="Login">Back to Login</a>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}